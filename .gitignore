```gitignore
# ══════════════════════════════════════════════
# NEXT.JS
# ══════════════════════════════════════════════
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# ══════════════════════════════════════════════
# NODE.JS
# ══════════════════════════════════════════════
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.npm
.yarn-integrity
*.tgz
package-lock.json
yarn.lock
.pnpm-debug.log*

# ══════════════════════════════════════════════
# BUILD & PRODUCTION
# ══════════════════════════════════════════════
/build
/dist
/out
/target
/.nuxt
/.cache

# ══════════════════════════════════════════════
# ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════
.env
.env*.local
.env.development
.env.test
.env.production

# ══════════════════════════════════════════════
# VERCEL
# ══════════════════════════════════════════════
.vercel

# ══════════════════════════════════════════════
# LOGS & DEBUG
# ══════════════════════════════════════════════
logs/
log/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ══════════════════════════════════════════════
# TESTING
# ══════════════════════════════════════════════
/coverage
/.nyc_output
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
htmlcov/
.tox/
.coverage
.coverage.*

# ══════════════════════════════════════════════
# PYTHON
# ══════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# ══════════════════════════════════════════════
# VIRTUAL ENVIRONMENTS
# ══════════════════════════════════════════════
env/
venv/
ENV/
env.bak/
venv.bak/
.venv/

# ══════════════════════════════════════════════
# IDEs & EDITORS
# ══════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/
*.sublime-*

# ══════════════════════════════════════════════
# OS FILES
# ══════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ══════════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════════
*.sqlite
*.sqlite3
*.db

# ══════════════════════════════════════════════
# TEMPORARY FILES
# ══════════════════════════════════════════════
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.old

# ══════════════════════════════════════════════
# DOCKER
# ══════════════════════════════════════════════
Dockerfile.local
docker-compose.override.yml

# ══════════════════════════════════════════════
# MISC
# ══════════════════════════════════════════════
*.pem
*.pid
*.seed
*.pid.lock
.grunt
.lock-wscroll
```